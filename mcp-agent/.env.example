# Anthropic API Key (passed via deploy script --anthropic-key flag)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# MongoDB (private IP within VPC)
MONGO_URI=mongodb://<MONGODB_PRIVATE_IP>:27017
MONGO_DB=coldchain

# Redis (EKS service)
REDIS_HOST=<REDIS_SERVICE_IP>
REDIS_PORT=6379

# Kafka (EKS service)
KAFKA_BOOTSTRAP_SERVERS=<KAFKA_SERVICE_IP>:9092

# MQTT (localhost on MQTT EC2)
MQTT_BROKER=localhost
MQTT_PORT=1883

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8001
